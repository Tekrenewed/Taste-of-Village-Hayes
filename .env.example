# ---------------------------------------------------------
# RESTAURANT OS - ENVIRONMENT VARIABLES
# ---------------------------------------------------------

# Server Configuration
PORT=8080

# Database Connection (PostgreSQL)
# Local Docker Example: postgres://postgres:password@localhost:5432/restaurant_os?sslmode=disable
# GCP Cloud SQL Example: postgres://USER:PASSWORD@/DB_NAME?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
DATABASE_URL=

# Dojo Payment API Integrations
DOJO_API_KEY=your_dojo_test_api_key
DOJO_API_URL=https://api.dojo.tech/v1

# Uber Direct Dispatch APIs
UBER_CLIENT_ID=your_uber_client_id
UBER_ACCESS_TOKEN=your_uber_access_token
UBER_DIRECT_API_URL=https://api.uber.com/v1
